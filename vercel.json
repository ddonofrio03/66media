{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/daily-digest",
      "schedule": "30 10 * * *"
    },
    {
      "path": "/api/cron/daily-digest",
      "schedule": "30 11 * * *"
    }
  ]
}

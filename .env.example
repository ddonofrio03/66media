APP_BASE_URL=http://localhost:3000
CRON_SECRET=replace-with-a-long-random-secret
EMAIL_FROM=66EMP Alerts <digest@alerts.thecaseygroup.us>
EMAIL_TO=ddonofrio@thecaseygroup.us,jason@thecaseygroup.us
RESEND_API_KEY=
TIMEZONE=America/New_York

# Shared HTTP Basic Auth gate for the whole site (cron endpoint excluded). When
# either is unset the gate is disabled, so the site stays open.
BASIC_AUTH_USER=66media
BASIC_AUTH_PASSWORD=

# Optional persistence (Supabase). When unset, the app still runs: it collects
# live and emails, but without cross-day dedup, once-per-day idempotency, or
# stored history. Set both to enable. Use the service-role key (server-only).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional social monitoring (Apify pay-per-result X + Facebook keyword search).
# OFF unless SOCIAL_ENABLED is exactly "true" AND APIFY_TOKEN is set, so it stays
# dark until you've added a token and set a spend ceiling in the Apify console
# ($5/mo recommended). X (Twitter) is the backbone; Facebook is best-effort.
# Runs only on the daily digest, capped at 50 items/run. Override the actor IDs
# only if you swap in a different scraper.
SOCIAL_ENABLED=false
APIFY_TOKEN=
# APIFY_X_ACTOR=apidojo/tweet-scraper
# APIFY_FB_ACTOR=apify/facebook-search-scraper
